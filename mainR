#SURVIVAL ANALYSIS
# os e dfs computation -----------------------------------------# ---------------------------------------------------------------------------
# overall survival
df_surv <- df
df_surv$death <- as.numeric(as.character(df_surv$death))
df_surv$recur <- as.numeric(as.character(df_surv$recur))
#NON PARAMETRIC ESTIMATOR, KM 
OS <- survfit(Surv(dtime, death) ~ 1,data = df_surv, conf.int=0.95)
summary(OS)
par(mfrow = c(1, 2))
#plot OS KM estimator
plot(OS,  xlab = "Time (days)",  ylab = "Survival function", 
main = "Kaplan–Meier estimator", col = "#2171B5",lwd = 2)
#plot cumulative hazard NA estimator
plot(OS, fun= "cumhaz", xlab = "Time (days)",ylab = "Cumulative hazard",
main = "Nelson–Aalen estimator", col = "#2171B5",lwd = 2)
par(mfrow = c(1, 1))
#PARAMETRIC estimators, flexsurvreg
#OS and cum.haz. approximation with exponential distribution 
mod_exp <- flexsurvreg(Surv(dtime, death)~ 1, dist = 'exp', data =df_surv )
plot(mod_exp)
plot(mod_exp, type="cumhaz")
#OS and cum.haz. approximation with weibull distribution
mod_wei <- flexsurvreg(Surv(dtime, death)~ 1, dist = 'weibull', data =df_surv)
plot(mod_wei)
plot(mod_wei, type="cumhaz")
#OS and cum.haz. approximation with log-normal distribution 
mod_lognorm <- flexsurvreg(Surv(dtime, death)~ 1, dist = 'lnorm', data =df_surv)
plot(mod_lognorm)
plot(mod_lognorm, type="cumhaz")
#OS and cum.haz. approximation with log-logistic distribution
mod_loglogis <- flexsurvreg(Surv(dtime, death)~ 1, dist = 'llogis', data =df_surv)
plot(mod_loglogis)
plot(mod_loglogis, type="cumhaz")
# --------------------
# plot parametric vs non parametric  
par(mfrow = c(1, 1))
plot(OS,conf.int = FALSE,col = "grey35",lwd = 2.5,xlab = "Time (days)", 
ylab = "Survival probability",
     main = "OS function - Parametric models vs Kaplan-Meier")
lines(mod_exp, col = "forestgreen",   lwd = 1.5, ci = FALSE)
lines(mod_wei, col = "darkmagenta",   lwd = 1.5, ci = FALSE)
lines(mod_lognorm, col = "firebrick3", lwd = 1.5, ci = FALSE)
lines(mod_loglogis, col = "darkslategray3", lwd = 1.5, ci = FALSE)
legend("topright",legend = c("Kaplan-Meier","Exponential","Weibull", "Log-normal",
"Log-logistic"),col = c("grey35",
"forestgreen","darkmagenta","firebrick3","darkslategray3"),
lwd = c(2.5, 1.5, 1.5, 1.5, 1.5),bty = "n",  cex = 0.9)
plot(OS,fun = "cumhaz",conf.int = FALSE,col = "grey35",lwd = 2.5,
xlab = "Time (days)",ylab = "Cumulative hazard",main = "Cumulative hazard
function - Parametric models vs Nelson Aelen")
lines(mod_exp,     type = "cumhaz", col = "forestgreen",   lwd = 1.5, ci = FALSE)
lines(mod_wei,     type = "cumhaz", col = "darkmagenta",   lwd = 1.5, ci = FALSE)
lines(mod_lognorm, type = "cumhaz", col = "firebrick3",    lwd = 1.5, ci = FALSE)
lines(mod_loglogis,type = "cumhaz", col = "darkslategray3",lwd = 1.5, ci = FALSE)
legend("topleft",legend = c("Kaplan-Meier","Exponential","Weibull",
"Log-normal","Log-logistic"),
       col = c("grey35","forestgreen","darkmagenta", "firebrick3",
       "darkslategray3"),
       lwd = c(2.5, 1.5, 1.5, 1.5, 1.5),bty = "n", cex = 0.9)
