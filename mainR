#with RFS and no OS
df_dfs <- df
df_dfs$grade <- factor(as.character(df_dfs$grade))
sapply(df_dfs, class)
df_dfs$dtime <- NULL      
df_dfs$death <- NULL   
str(df_dfs)
syn_t0_dfs <- syn(df_dfs, m = 0, seed = 2025, print.flag = TRUE)
method_dfs <- syn_t0_dfs$method 
pm_dfs<-syn_t0_dfs$predictor.matrix
vseq_dfs <- names(syn_t0_dfs$visit.sequence)
#set method for survival variable dtime, death
method_dfs["rtime"] <- "survctree"
method_dfs["recur"] <- ""             
syn_dfs_fit <- syn(data= df_dfs,m= 1, method= method_dfs,predictor.matrix = pm_dfs,visit.sequence= vseq_dfs,
                   event= list(rtime = "recur"),seed= 2025,print.flag= TRUE)
synthp_syn_dfs <- syn_dfs_fit$syn
#compare(data=synthp_syn_dfs, object= df_dfs)
df_dfs$data <- "Original"
synthp_syn_dfs$data <- "Synthetic"
combined <- bind_rows(df_dfs, synthp_syn_dfs)
cont_vars <- c("age", "nodes", "pgr", "er", "rtime")
cat_vars  <- c("meno", "size", "grade", "hormon", "chemo", "recur")
plot_bar("size")
plots_cat  <- lapply(cat_vars, plot_bar)
plots_cont <- lapply(cont_vars, plot_histogram)
all_plots <- c(plots_cont, plots_cat)
do.call(grid.arrange, c(all_plots, ncol = 3,top = "Original vs Synthetic data, covariates + DFS, synthpop"))
#pMSE
all_vars  <- c(cont_vars, cat_vars)
df_dfs$data <- 0 
synthp_syn_dfs$data <- 1 
combined <- bind_rows(df_dfs, synthp_syn_dfs)
pmse_variable_results <- do.call(rbind,lapply(all_vars, compute_pMSE, data = combined))
pmse_variable_results

