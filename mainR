#logrank test
cat_vars <- c("meno","size","grade","hormon","chemo")
get_logrank <- function(data, time, event, vars, dataset_name){
  data[[event]] <- as.numeric(as.character(data[[event]]))
  res <- lapply(vars, function(v){
    fit <- survdiff(as.formula(paste0("Surv(",time,",",event,") ~ ",v)), data=data)
    data.frame(Dataset = dataset_name,Variable = v, pvalue = round(fit$pvalue),4) })
  do.call(rbind,res)
}
